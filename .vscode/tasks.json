{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "ArcEngine: Configure Release",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--preset",
        "windows-release"
      ],
      "problemMatcher": []
    },
    {
      "label": "ArcEngine: Build Release",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "--preset",
        "windows-release"
      ],
      "problemMatcher": "$msCompile",
      "dependsOn": [
        "ArcEngine: Configure Release"
      ]
    },
    {
      "label": "ArcEngine: Build and Run Release",
      "type": "shell",
      "command": "${workspaceFolder}/Build/Release/Game/Release/ArcGame.exe",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": [
        "ArcEngine: Build Release"
      ],
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}